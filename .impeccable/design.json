  "narrative": {
    "northStar": "Quiet Calibration",
    "overview": "The interface should feel like a carefully prepared skincare formula translated into space, type, and sequence. Warm paper surfaces keep the laboratory language humane; graphite typography supplies authority; measured Morandi accents identify formulas without turning the routine into a color-coded toy. The system is precise and tactile. Depth comes from tonal shifts, hairline rules, scale, and generous spacing rather than ornamental effects.",
    "keyCharacteristics": ["Warm paper field with dark, readable ink", "Product-first editorial pacing and large negative space", "Fine laboratory rules and structured formula metadata", "Muted SKU colors paired with names and numbers", "Flat, responsive surfaces with restrained motion"],
    "rules": [
      { "name": "The Calibration Rule", "body": "Every decorative choice must clarify product, routine, or evidence. If it does none of those jobs, remove it.", "section": "overview" },
      { "name": "The Ink First Rule", "body": "Body copy uses Northern Ink or Graphite. Taupe is never body text and must not carry essential information.", "section": "colors" },
      { "name": "The Named Formula Rule", "body": "Color never communicates an SKU, serum choice, or routine step on its own.", "section": "colors" },
      { "name": "The Evidence Reads Easily Rule", "body": "Instructions, claims, and ingredient explanations never use mono, italics, or low-contrast taupe as their primary style.", "section": "typography" },
      { "name": "The Flat by Default Rule", "body": "Cards and product fields sit on the page plane. Hover changes tone or spacing; it never introduces a wide ambient shadow.", "section": "elevation" }
    ],
    "dos": ["Do maintain WCAG 2.2 AA contrast, visible keyboard focus, semantic structure, and comfortable mobile touch targets.", "Do pair each Morandi SKU accent with product name, formula number, and routine role.", "Do use the cleanser-plus-moisturiser pairing as the clearest starting route for reactive or compromised skin.", "Do respect prefers-reduced-motion; content must remain visible without animation."],
    "donts": ["Don't use sterile dermatology-clinic aesthetics, cold medical blue, stock model imagery, or hospital-like interfaces.", "Don't use generic clean-beauty imagery such as leaves, water splashes, beige bottles, or vague sustainability claims.", "Don't use loud pastel beauty styling, cute icons, TikTok gradients, glow effects, excessive motion, or inflated claims.", "Don't directly imitate Aesop or Le Labo through dense apothecary labels or copied packaging logic.", "Don't use low-contrast beige-on-beige styling.", "Don't rely on color alone to distinguish Rav Perle from Glød or any other SKU."]
  }
